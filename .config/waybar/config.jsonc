	"cpu": {
		"interval": 1,
		"format": "пӢӣ  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
		"format-icons": ["в–Ғ", "в–Ӯ", "в–ғ", "в–„", "в–…", "в–Ҷ", "в–Ү", "в–Ҳ"],
		"on-click": "ghostty -e htop"
	},

	"memory": {
		"interval": 30,
		"format": "оҝ…  {used:0.1f}G/{total:0.1f}G", "tooltip-format": "Memory"
	},

	"temperature": {
		"critical-threshold": 80,
		"format": "{temperatureC}В°C {icon}",
		"format-icons": ["пқ«", "пӢү", "пқ©"]
	},

	"clock": {
		"timezone": "Asia/Kolkata",
		"tooltip": false,
		"format": "{:%H:%M  %A,%d}",
		"interval": 1
	},
	"custom/notification":{
		"format" : "у°Ӯҡ",
		"tooltip": true,
		"tooltip-format": "Notifications",
		"on-click":"swaync-client -t"
	},

	"backlight": {
		"format": "{icon}  {percent}%",
		"format-icons": ["оҺҚ","у°ғң", "у°ғӣ", "у°ғһ","у°ғқ","у°ғҹ","у°ғ "],
		"tooltip": false 
	},

	"battery": {
		"states": {
			// "good": 95,
			"warning": 30,
			"critical": 15
		},
		"format": "{capacity}% {icon}",
		"format-full": "{capacity}% {icon}",
		"format-charging": "{capacity}% вҡЎпёҺ",
		"format-plugged": "{capacity}% пҮҰ",
		"format-alt": "{time} {icon}",
		"format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"]
	},

	"network": {
		"format-wifi": "у°Өў",
		"format-ethernet": "у°ҲҖ ",
		"format-disconnected": "у°Ө  ",
		"interval": 5,
		"tooltip-format": "{essid} ({signalStrength}%)",
		"on-click": "nmtui"

	},

	"wireplumber": {
		"scroll-step": 5,
		"format": "{icon} {volume}%",
		"format-bluetooth": "{icon} {volume}% пҠ”",
		"format-bluetooth-muted": "у°қҹ {icon}пҠ”",
		"format-muted": "у°қҹ",
		"format-icons": {
			"headphone": "пҖҘ",
			"hands-free": "у°ӢҢ",
			"headset": "у°ӢҺ",
			"phone": "пӮ•",
			"portable": "пӮ•",
			"car": "пҶ№",
			"default": ["пҖҰ :", "пҖ§ :", "пҖЁ :"]
		},
		"on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
		"on-click-right": "pavucontrol"
	},

	"bluetooth": {
		"format": "у°ӮІ",
		"format-on": "{icon}",
		"format-off": "{icon}", 
		"format-connected":"{icon}",
		"format-icons":{
			"on":"у°ӮҜ",
			"off": "у°ӮІ",
			"connected": "у°Ӯұ"
		},
		"on-click": "blueman-manager",
		"tooltip-format-connected":"{device_enumerate}"
	},

	"custom/power": {
		"format" : "вҸ» ",
		"tooltip": false
	}
}
